FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      changeDictionaryDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

numberOfSubdomains  30;

method      hierarchical;

hierarchicalCoeffs
{
    n               ( 6 1 5 );
    delta           0.001;
    order           xyz;
}

