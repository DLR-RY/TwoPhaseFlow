FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    atmosphere
    {
        type pressureInletOutletVelocity;
        value   uniform (0 0 0);
    }

    fluid_to_solid
    {
        type noSlip;
    }
    
    symmetry
    {
        type symmetry;
    }
}

